// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User{
  id                Int       @id      @default(autoincrement())
  username          String
  email             String             @unique
  password          String
  refreshToken      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  gitInstallations  GitInstallation[]
  repositories      Repository[]
  revieRuns         ReviewRun[]
}

model Repository{
  id                 Int       @id    @default(autoincrement())
  userId             Int
  owner              String
  name               String
  provider           String
  providerRepoId     String
  gitInstallationId  Int
  repoUrl            String
  defaultBranch             String           @default("main")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id])
  gitInstallation    GitInstallation  @relation(fields: [gitInstallationId], references: [id])
  pullRequests       PullRequest[]
  repoFiles          RepoFile[]
  repoSymbols        RepoSymbol[]
  repoMaps           RepoMap[]
  repoEdge           RepoEdge[]
  agentMemory        AgentMemory[]

  @@unique([provider, owner, name])
  @@unique([provider, providerRepoId])
}

model GitInstallation {
  id                 Int        @id @default(autoincrement())
  provider           String     // github, gitlab
  installationId     String     @unique
  userId             Int?
  accountLogin       String
  accountType        String     // User or Organization
  accessTokenHash    String?
  tokenExpiresAt     DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  repository         Repository[]
  user                User?     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PullRequest {
  id              Int      @id @default(autoincrement())
  repositoryId    Int
  providerPrId    String
  number          Int
  title           String
  author          String
  state           String   // open, closed, merged
  baseBranch      String
  headBranch      String
  baseSha         String
  headSha         String
  diffUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repository      Repository @relation(fields: [repositoryId], references: [id])
  reviewRuns      ReviewRun[]

  @@unique([repositoryId, number])
}

model ReviewRun {
  id              Int      @id @default(autoincrement())
  userId          Int?
  pullRequestId   Int
  status          String   // queued, running, completed, failed
  triggerType     String   // webhook, manual, scheduled
  model           String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  errorMessage    String?

  summary         String?
  riskLevel       String?  // low, medium, high
  tokensUsed      Int?
  costCents       Int?

  user            User?        @relation(fields: [userId], references: [id])
  pullRequest     PullRequest  @relation(fields: [pullRequestId], references: [id])
  findings        ReviewFinding[]
  comments        ReviewComment[]
}

model ReviewFinding {
  id              Int      @id @default(autoincrement())
  reviewRunId     Int
  filePath        String
  lineStart       Int?
  lineEnd         Int?
  severity        String   // info, low, medium, high, critical
  category        String   // bug, security, performance, style, test, maintainability
  title           String
  body            String
  suggestedFix    String?
  confidence      Float?
  fingerprint     String   // stable hash to dedupe repeated findings
  createdAt       DateTime @default(now())

  reviewRun       ReviewRun @relation(fields: [reviewRunId], references: [id])

  @@index([fingerprint])
}

model ReviewComment {
  id                  Int      @id @default(autoincrement())
  reviewRunId         Int
  providerCommentId   String?
  filePath            String?
  lineNumber          Int?
  body                String
  status              String   // pending, posted, failed, dismissed
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  reviewRun           ReviewRun @relation(fields: [reviewRunId], references: [id])
}

model RepoFile {
  id              Int      @id @default(autoincrement())
  repositoryId    Int
  path            String
  blobSha         String
  size            Int?
  language        String?
  contentHash     String
  isGenerated     Boolean  @default(false)
  indexedAt       DateTime @default(now())

  repository      Repository @relation(fields: [repositoryId], references: [id])

  @@unique([repositoryId, path, blobSha])
}

model RepoSymbol {
  id              Int      @id @default(autoincrement())
  repositoryId    Int
  path            String
  blobSha         String
  symbolName      String
  symbolType      String   // function, class, method, variable, type
  startLine       Int
  endLine         Int
  summary         String?
  embeddingId     String?
  createdAt       DateTime @default(now())

  repository      Repository @relation(fields: [repositoryId], references: [id])

  @@index([repositoryId, path])
  @@index([symbolName])
}

model RepoEdge {
  id              Int      @id @default(autoincrement())
  repositoryId    Int
  fromPath        String
  fromSymbol      String?
  toPath          String
  toSymbol        String?
  edgeType        String   // imports, calls, extends, implements, reads, writes

  repository      Repository @relation(fields: [repositoryId], references: [id])

  @@index([repositoryId, fromPath])
  @@index([repositoryId, toPath])
}

model RepoMap {
  id              Int      @id @default(autoincrement())
  repositoryId    Int
  baseCommitSha   String
  mapText         String
  createdAt       DateTime @default(now())

  repository      Repository @relation(fields: [repositoryId], references: [id])

  @@unique([repositoryId, baseCommitSha])
}

model AgentMemory {
  id              Int      @id @default(autoincrement())
  repositoryId    Int
  key             String
  value           String
  source          String?  // user, agent, repo, review
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repository      Repository @relation(fields: [repositoryId], references: [id])

  @@unique([repositoryId, key])
}
